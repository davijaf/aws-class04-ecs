# Copie para .env e preencha com a SUA infra:  cp .env.example .env
# O .env NAO e versionado (esta no .gitignore). Os scripts deploy-*.sh leem dele.

ACCOUNT=000000000000                 # ID da sua conta AWS
REGION=us-east-2                     # regiao
EC2_HOST=<ip-publico-da-sua-ec2>     # alvo do deploy-ecr.sh (docker direto na EC2)
EC2_KEY=~/Downloads/<sua-chave>.pem  # chave SSH da EC2
SG=<sg-id-da-task>                   # security group (porta 8080) usado no deploy-ecs.sh
